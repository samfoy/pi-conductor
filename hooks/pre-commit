#!/usr/bin/env bash
# pi-conductor pre-commit hook.
#
# When `src/` files are staged, rebuilds `dist/index.js` and auto-stages
# the result — `dist/` is a tracked artifact whose only legitimate state
# is "matches src/". Then runs the unit test suite. Rejects the commit on
# any red test or build failure.
#
# To activate this hook in your clone, run:
#   git config core.hooksPath hooks
# or:
#   ./scripts/install-hooks.sh
#
# To bypass for a real emergency (almost never appropriate):
#   git commit --no-verify
set -euo pipefail

# Find repo root regardless of where git invokes us.
repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [[ ! -f package.json ]]; then
  echo "pre-commit: no package.json at $repo_root, skipping" >&2
  exit 0
fi

if [[ ! -d node_modules ]]; then
  echo "pre-commit: node_modules missing — run 'npm install' first" >&2
  exit 1
fi

# Rebuild dist/ when src/ is touched. dist/index.js is a tracked artifact
# whose only legitimate state is "matches src/" — staleness has bitten three
# slices in a row (ff9a40e, cfeffb5, 1c72856), so we automate the rebuild and
# auto-stage the result. Build cost is ~30ms wall (esbuild) when fired;
# guarded so doc-/persona-/test-only commits pay nothing.
if git diff --cached --name-only | grep -q '^src/'; then
  echo "pre-commit: rebuilding dist/ (src/ changes detected)…"
  if ! npm run build --silent; then
    echo
    echo "pre-commit: build FAILED. Commit rejected." >&2
    echo "pre-commit: fix the build, then commit again." >&2
    exit 1
  fi
  git add dist/index.js dist/index.js.map
fi

echo "pre-commit: running npm test (unit suite)…"
# v0.10 watchdog: env var must be unset for the unit suite. The R7
# guard in `Watchdog.start()` makes the enforcer a no-op when
# CONDUCTOR_SUBAGENT=1, which the watchdog-enforcer tests interpret
# as a failure (they assert the enforcer ticks and dispatches). When
# the hook fires from inside a conductor sub-agent (e.g. the builder
# running this commit), CONDUCTOR_SUBAGENT=1 is inherited and the
# tests fail spuriously. Unset it for the test run only.
if ! env -u CONDUCTOR_SUBAGENT npm test --silent; then
  echo
  echo "pre-commit: tests FAILED. Commit rejected." >&2
  echo "pre-commit: fix the tests or the code, then commit again." >&2
  echo "pre-commit: emergency bypass (rare): git commit --no-verify" >&2
  exit 1
fi

echo "pre-commit: tests green."
